# Required for a single bot
TOKEN=your_discord_bot_token

# Or use this for multiple bots in one Node.js process
# TOKENS=first_discord_bot_token,second_discord_bot_token

# Optional bot settings
PREFIX=.
OWNERID=123456789012345678
COLOR="#DDBD86"
LOGS=

# Optional links shown by commands
SUPPORT=
INVITE=
VOTE=
BG=

# Optional Spotify search support
SPOTIFYID=
SPOTIFYSECRET=

# Internal Lavalink password used by docker-compose.yml and lavalink/application.yml
LAVALINK_PORT=8080
LAVALINK_PASSWORD=youshallnotpass
LAVALINK_WAIT_TIMEOUT_MS=120000

# Memory limits for Coolify/docker-compose. Raise these if audio playback is unstable.
BOT_MEMORY_LIMIT=256m
MONGO_MEMORY_LIMIT=256m
LAVALINK_MEMORY_LIMIT=512m
LAVALINK_JAVA_OPTIONS=-Xmx384m
